{
  "name": "xuanshen",
  "private": true,
  "version": "1.0.2",
  "description": "AI Desktop Pet",
  "scripts": {
    "start": "bash start.sh",
    "dev": "pnpm --filter desktop-pet dev",
    "build": "pnpm --filter desktop-pet build",
    "pack": "pnpm build && pnpm --filter desktop-pet pack",
    "dist": "pnpm build && pnpm --filter desktop-pet dist",
    "dist:mac": "pnpm build && pnpm --filter desktop-pet dist:mac",
    "dist:win": "pnpm build && pnpm --filter desktop-pet dist:win",
    "dist:all": "pnpm build && pnpm --filter desktop-pet dist:all",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18"
  }
}